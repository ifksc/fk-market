# FK.market — пример .env. Скопируйте в src/.env и поправьте под себя.
APP_NAME="FK.market"
APP_ENV=local                  # local | staging | production
APP_KEY=                       # сгенерится `php artisan key:generate`
APP_DEBUG=true                 # на проде: false
APP_URL=http://localhost:8000  # на проде: https://fk.market (сервер 194.87.118.214)
APP_LOCALE=ru
APP_TIMEZONE=Europe/Moscow

LOG_CHANNEL=stack
LOG_LEVEL=debug

# База данных (имена хостов — как в docker-compose.yml)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=fk_market
DB_USERNAME=fk_user
DB_PASSWORD=fk_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Очереди
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Email (заполните позже)
MAIL_MAILER=log                # log — пишет письма в storage/logs/laravel.log (удобно для разработки)
MAIL_FROM_ADDRESS="no-reply@fk.market"
MAIL_FROM_NAME="${APP_NAME}"

# ==================== FKwallet ====================
FKWALLET_MERCHANT_ID=
FKWALLET_SECRET_WORD_1=
FKWALLET_SECRET_WORD_2=
FKWALLET_API_KEY=
FKWALLET_SANDBOX=true

# ==================== OAuth ====================
VK_CLIENT_ID=
VK_CLIENT_SECRET=
# Redirect URI зарегистрирован в кабинете id.vk.com:
# dev:  http://localhost:3000/oauth/vk/callback
# prod: https://fk.market/oauth/vk/callback

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8000/api/auth/yandex/callback

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ==================== Поставщики ====================
DIGISELLER_SELLER_ID=
DIGISELLER_API_KEY=

KINGUIN_API_KEY=

# ==================== FKwallet Online Products ====================
# Ключи из ЛК FKwallet → https://fkwallet.io/personal/settings/api-key
# Авторизация: X-Api-Key: {public} + Authorization: Bearer sha256(body + private)
FKWALLET_OP_KEY=
FKWALLET_OP_PRIVATE_KEY=
FKWALLET_OP_BASE_URL=https://api.fkwallet.com/v1
FKWALLET_OP_CURRENCY_ID=1
