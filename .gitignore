backend/db/dumps/

# --- Frontend (Next.js) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/.turbo/
frontend/*.tsbuildinfo

# --- Временные ---
/tmp/
.tmp/
*.bak
*.backup
*.tmp
*.tar.gz

